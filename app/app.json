{
  "expo": {
    "name": "Home Automation",
    "slug": "home-automation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.homeautomation.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.homeautomation.app"
    },
    "extra": {
      "eas": {
        "projectId": "ac56a614-293a-4158-a338-e222c98786b0"
      }
    },
    "plugins": [
      "expo-asset"
    ],
    "owner": "raone18"
  }
}
