# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://homeauto:homeauto123@localhost:5432/home_automation"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# App Configuration
APP_NAME="Home Automation"
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# MQTT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=home_automation
MQTT_PASSWORD=mqtt_pass_123
MQTT_TOPIC_PREFIX=home

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
